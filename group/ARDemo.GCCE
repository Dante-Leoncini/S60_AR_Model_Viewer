	$(EPOCLIB)\LIB\imageconversion.dso \
	$(EPOCLIB)\LIB\platformenv.dso \
	$(EPOCLIB)\LIB\aknskins.dso \
	$(EPOCLIB)\LIB\efsrv.dso \
	$(EPOCLIB)\LIB\bafl.dso \
	$(EPOCLIB)\LIB\apgrfx.dso \
