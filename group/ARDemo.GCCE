	$(EPOCLIB)\LIB\hlplch.dso \
	$(EPOCLIB)\LIB\sysutil.dso \
	$(EPOCLIB)\LIB\CommonEngine.dso \
	$(EPOCLIB)\LIB\centralrepository.dso \
	$(EPOCLIB)\LIB\libgles_cm.dso \
	$(EPOCLIB)\LIB\HWRMLightClient.dso \
	$(EPOCLIB)\LIB\estor.dso \
	$(EPOCLIB)\LIB\dfpaeabi.dso \
	$(EPOCLIB)\LIB\dfprvct2_2.dso \
	$(EPOCLIB)\LIB\drtaeabi.dso \
	$(EPOCLIB)\LIB\scppnwdl.dso \
	$(EPOCLIB)\LIB\drtrvct2_2.dso \
	$(STATIC_LIBS_LIST)

VTBLEXPORTSUREL=

OBJECTSUREL= \
	$(EPOCBLDUREL)\CameraAppApp.o \
	$(EPOCBLDUREL)\CameraAppAppUi.o \
	$(EPOCBLDUREL)\CameraAppDocument.o \
	$(EPOCBLDUREL)\CameraAppBaseContainer.o \
	$(EPOCBLDUREL)\CameraAppView.o \
	$(EPOCBLDUREL)\CameraCaptureEngine.o \
	$(EPOCBLDUREL)\CameraAppController.o \
	$(EPOCBLDUREL)\CGLengine.o \
	$(EPOCBLDUREL)\bitmapmethods.o \
	$(EPOCBLDUREL)\CPictureLoader.o \
	$(EPOCBLDUREL)\eikonenvironment.o \
	$(EPOCBLDUREL)\PhEngine.o \
	$(EPOCBLDUREL)\pltIndependentPh.o \
	$(EPOCBLDUREL)\text.o \
	$(EPOCBLDUREL)\CreateObjGL.o

$(EPOCTRGUREL)\ARDemo.exe : $(OBJECTSUREL)
	-$(ERASE) "$(EPOCTRGUREL)\ARDemo.exe.map" 
	$(LD) $(STATIC_LIBS) $(SYMBIAN_UREL_LINK_FLAGS) $(SHARED_OBJECT_OPTION) $(CODE_SEGMENT_START) $(DATA_SEGMENT_START) 0x400000 $(SYMVER_OPTION) $(SO_NAME_OPTION) ARDemo{000a0000}[a000ffdf].exe $(LINKER_ENTRY_OPTION) _E32Startup  $(UNDEFINED_SYMBOL_REF_OPTION) _E32Startup  $(EPOCSTATLINKUREL)\EEXE.LIB$(EEXE_OBJECT) \
		$(LINKER_OUTPUT_OPTION) "$(EPOCBLDUREL)\ARDemo.exe" \
		$(LINKER_SYMBOLS_MAP_OPTION) $(UREL_MAP_FILE) \
		$(OBJECTSUREL) \
		$(LIBSUREL) \
		$(VTBLEXPORTSUREL) $(USERLDFLAGS) 
	elf2e32 --sid=0xa000ffdf  --heap=0x00100000,0x01300000 --stack=0x00010000\
		 --uid1=0x1000007a --uid2=0x100039ce --uid3=0xa000ffdf --vid=0x00000000\
		 --capability=UserEnvironment --fpu=vfpv2 --targettype=EXE --output="$@" --elfinput="$(EPOCBLDUREL)\ARDemo.exe" --linkas=ARDemo{000a0000}[a000ffdf].exe --compressionmethod none --libpath="$(EPOCLIB)\LIB"


