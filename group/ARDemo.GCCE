	LISTINGURELCPictureLoader \
	LISTINGURELeikonenvironment \
	LISTINGURELPhEngine \
	LISTINGURELpltIndependentPh \
	LISTINGURELtext \
	LISTINGURELCreateObjGL

LIBSUREL= \
	-( \
	$(EPOCSTATLINKUREL)\usrt2_2.lib \
	$(EPOCSTATLINKUREL)\smmt.lib \
	-) \
	$(EPOCLIB)\LIB\euser.dso \
	$(EPOCLIB)\LIB\apparc.dso \
	$(EPOCLIB)\LIB\cone.dso \
	$(EPOCLIB)\LIB\eikcore.dso \
